{
  "name": "bol-order-get-organize",
  "version": "1.0.0",
  "private": true,
  "description": "BOL订单获取整理 - Windows Electron app scaffold",
  "main": "src/main.js",
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "dist": "electron-builder --win nsis --publish never"
  },
  "build": {
    "appId": "com.codex.bolorderorganize",
    "productName": "BOL订单获取整理",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "screenshot-desktop": "^1.15.0",
    "tesseract.js": "^5.1.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^25.1.8"
  }
}
